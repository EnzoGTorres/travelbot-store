TELEGRAM_BOT_TOKEN=coloca_aqui_tu_token
TELEGRAM_CHAT_ID=coloca_aqui_tu_chat_id
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_API_KEY=coloca_aqui_tu_serpapi_api_key
SERPAPI_KEY=coloca_aqui_tu_serpapi_api_key_opcional
SERPAPI_CURRENCY=USD
SERPAPI_LANGUAGE=en
SERPAPI_MARKET=us
SERPAPI_REQUEST_TIMEOUT_MS=8000

# Seguridad del endpoint serverless
TRAVELBOT_CHECK_SECRET=coloca_aqui_un_secret_largo
TRAVELBOT_DRY_RUN=false
TRAVELBOT_FLIGHT_FETCH_CONCURRENCY=8

# Persistencia: local por defecto
TRAVELBOT_STORE_PROVIDER=file
TRAVELBOT_ALERTS_FILE=data/alerts.json

# Persistencia alternativa para Vercel usando GitHub Contents API
GITHUB_STORE_OWNER=tu_usuario_o_org
GITHUB_STORE_REPO=tu_repo
GITHUB_STORE_BRANCH=main
GITHUB_STORE_PATH=data/alerts.json
GITHUB_STORE_TOKEN=github_pat_con_permiso_contents

# Diagnostico opcional del store al arrancar con npm run dev
TRAVELBOT_RUN_STORE_DIAGNOSTIC=false

# Kiwi.com Tequila API (alternativa a SerpAPI — registro gratuito en tequila.kiwi.com)
# Ventaja: soporta rangos de fechas en un solo request, free tier publico
KIWI_API_KEY=coloca_aqui_tu_kiwi_api_key
KIWI_REQUEST_TIMEOUT_MS=10000
